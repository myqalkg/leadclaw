.container { background: #f7f7f7; min-height: 100vh; padding-bottom: 120rpx; }
.header { padding: 40rpx 30rpx; background: #fff; display: flex; justify-content: space-between; align-items: center; border-bottom: 1rpx solid #eee; }
.title { font-size: 40rpx; font-weight: 900; color: #EA580C; font-style: italic; }
.feed { display: flex; flex-wrap: wrap; padding: 20rpx; }
.item-card { width: 48%; background: #fff; margin-bottom: 20rpx; border-radius: 20rpx; position: relative; display: inline-block; margin-right: 2%; vertical-align: top; overflow: hidden; }
.score-badge { position: absolute; top: 10rpx; left: 10rpx; background: #ff4d4f; color: #fff; font-size: 20rpx; padding: 4rpx 10rpx; border-radius: 4rpx; z-index: 10; }
.thumb { width: 100%; height: 340rpx; }
.info { padding: 15rpx; }
.item-title { font-size: 24rpx; font-weight: bold; height: 64rpx; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.price { color: #ff4d4f; font-size: 32rpx; font-weight: 900; }
.old { font-size: 20rpx; color: #999; text-decoration: line-through; margin-left: 10rpx; }
.auth-bar { position: fixed; bottom: 0; width: 100%; background: rgba(0,0,0,0.8); color: #fff; display: flex; justify-content: space-between; align-items: center; padding: 30rpx; }
.auth-btn { background: #EA580C; color: #fff; font-size: 24rpx; height: 60rpx; line-height: 60rpx; border-radius: 30rpx; }
.auth-bar { position: fixed; bottom: 30rpx; left: 20rpx; right: 20rpx; background: rgba(0,0,0,0.9); height: 100rpx; border-radius: 20rpx; display: flex; align-items: center; justify-content: space-between; padding: 0 30rpx; z-index: 9999; box-shadow: 0 10rpx 40rpx rgba(0,0,0,0.5); }
.auth-left { display: flex; align-items: center; }
.auth-icon { width: 60rpx; height: 60rpx; background: #EA580C; border-radius: 12rpx; text-align: center; line-height: 60rpx; margin-right: 20rpx; }
.auth-info { display: flex; flex-direction: column; }
.auth-title { color: #fff; font-size: 24rpx; font-weight: bold; }
.auth-sub { color: #999; font-size: 18rpx; }
.auth-btn { background: #EA580C; color: #fff; font-size: 20rpx; font-weight: 900; margin: 0; padding: 0 30rpx; height: 60rpx; line-height: 60rpx; border-radius: 30rpx; }
.bottom-padding { width: 100%; height: 150rpx; }
