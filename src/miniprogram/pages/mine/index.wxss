.container { background: #f7f7f7; min-height: 100vh; padding: 30rpx; }
.user-info { background: #fff; padding: 40rpx; border-radius: 30rpx; display: flex; align-items: center; margin-bottom: 30rpx; }
.avatar { width: 100rpx; height: 100rpx; background: #EA580C; border-radius: 50rpx; display: flex; align-items: center; justify-content: center; font-size: 50rpx; margin-right: 30rpx; }
.nickname { font-weight: bold; font-size: 32rpx; }
.section { background: #fff; border-radius: 30rpx; padding: 30rpx; }
.section-title { font-weight: 900; font-size: 28rpx; margin-bottom: 30rpx; border-left: 8rpx solid #EA580C; padding-left: 20rpx; }
.sub-item { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.sub-kw { font-size: 26rpx; font-weight: bold; }
.sub-status { font-size: 20rpx; color: #green; margin-left: 10rpx; color: #22C55E; }
.sub-count { font-size: 22rpx; color: #EA580C; font-weight: bold; }
.login-btn { background: #EA580C; color: #fff; font-size: 28rpx; border-radius: 50rpx; width: 100%; border: none; }
.avatar-real { width: 100rpx; height: 100rpx; border-radius: 50rpx; margin-right: 30rpx; border: 4rpx solid #EA580C; }
